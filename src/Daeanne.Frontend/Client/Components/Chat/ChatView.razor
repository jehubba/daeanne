@using DaeanneFrontend.Client.Models

<div class="d-flex flex-column" style="height: calc(100vh - 120px);">
    <div class="flex-grow-1 overflow-auto pa-2" @ref="_scrollContainer">
        @if (!Messages.Any())
        {
            <MudAlert Severity="Severity.Info" Class="ma-4">
                Send a command to Daeanne to get started.
            </MudAlert>
        }
        @foreach (var message in Messages)
        {
            <DaeanneFrontend.Client.Components.Chat.ChatBubble Message="@message" />
        }
    </div>
    <MudPaper Class="pa-2" Elevation="4" Style="position: sticky; bottom: 56px;">
        <div class="d-flex gap-2">
            <MudTextField @bind-Value="_inputText" Placeholder="Type a command..." Variant="Variant.Outlined"
                          FullWidth="true" Immediate="true" OnKeyDown="OnKeyDown" Class="flex-grow-1" />
            <MudIconButton Icon="@Icons.Material.Filled.Send" Color="Color.Primary"
                           Disabled="@string.IsNullOrWhiteSpace(_inputText)" OnClick="OnSend" />
        </div>
    </MudPaper>
</div>

@code {
    [Parameter]
    public List<ChatMessage> Messages { get; set; } = new();

    [Parameter]
    public EventCallback<string> OnMessageSent { get; set; }

    private string _inputText = string.Empty;
    private ElementReference _scrollContainer;

    private async Task OnSend()
    {
        if (string.IsNullOrWhiteSpace(_inputText)) return;
        var text = _inputText;
        _inputText = string.Empty;
        await OnMessageSent.InvokeAsync(text);
    }

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey)
        {
            await OnSend();
        }
    }
}
