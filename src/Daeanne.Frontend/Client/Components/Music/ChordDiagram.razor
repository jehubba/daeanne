@using DaeanneFrontend.Shared

<div style="display:inline-flex;flex-direction:column;align-items:center;gap:2px;margin:4px 8px">
    <svg width="@SvgWidth" height="@SvgHeight" viewBox="0 0 @SvgWidth @SvgHeight">
        @* Nut: thick when diagram starts at fret 1, thin with position label otherwise *@
        <line x1="@Margin" y1="@TopPad"
              x2="@(Margin + 5 * StrSpc)" y2="@TopPad"
              stroke="currentColor"
              stroke-width="@(_startFret == 1 ? 3 : 1)" />

        @* Horizontal fret lines *@
        @for (int f = 1; f <= 5; f++)
        {
            var fy = TopPad + f * FrtSpc;
            <line x1="@Margin" y1="@fy"
                  x2="@(Margin + 5 * StrSpc)" y2="@fy"
                  stroke="currentColor" stroke-width="0.5" opacity="0.5" />
        }

        @* Vertical string lines *@
        @for (int s = 0; s < 6; s++)
        {
            var sx = Margin + s * StrSpc;
            <line x1="@sx" y1="@TopPad"
                  x2="@sx" y2="@(TopPad + 5 * FrtSpc)"
                  stroke="currentColor" stroke-width="0.8" opacity="0.6" />
        }

        @* Per-string markers: x, o, or filled dot *@
        @foreach (var info in _stringInfos)
        {
            if (info.IsMuted)
            {
                @((MarkupString)$"<text x=\"{info.X}\" y=\"{TopPad - 5}\" font-size=\"9\" text-anchor=\"middle\" fill=\"currentColor\" opacity=\"0.8\">×</text>")
            }
            else if (info.IsOpen)
            {
                <circle cx="@info.X" cy="@(TopPad - 7)" r="3"
                        fill="none" stroke="currentColor" stroke-width="1" opacity="0.8" />
            }
            else if (info.RelFret >= 1 && info.RelFret <= 5)
            {
                var dotY = TopPad + (info.RelFret - 1) * FrtSpc + FrtSpc / 2;
                <circle cx="@info.X" cy="@dotY" r="5" fill="currentColor" />
            }
        }

        @* Fret position label for barre chords that don't start at fret 1 *@
        @if (_startFret > 1)
        {
            @((MarkupString)$"<text x=\"{Margin + 5 * StrSpc + 5}\" y=\"{TopPad + FrtSpc / 2 + 3}\" font-size=\"9\" fill=\"currentColor\" opacity=\"0.8\">{_startFret}</text>")
        }
    </svg>
    <span style="font-size:12px;font-weight:600">@Chord.Name</span>
</div>

@code {
    [Parameter, EditorRequired]
    public ChordDto Chord { get; set; } = default!;

    private const int StrSpc = 12;
    private const int FrtSpc = 14;
    private const int Margin = 8;
    private const int TopPad = 18;
    private const int SvgWidth = Margin * 2 + 5 * StrSpc;   // 76
    private const int SvgHeight = TopPad + 5 * FrtSpc + 6;  // 94

    private List<StringInfo> _stringInfos = [];
    private int _startFret = 1;

    private record StringInfo(int X, bool IsMuted, bool IsOpen, int RelFret);

    protected override void OnParametersSet()
    {
        var fretStr = (Chord.Frets ?? "xxxxxx").PadRight(6, 'x')[..6];
        var parsed = fretStr.Select(c => c switch
        {
            'x' => -1,
            '0' => 0,
            >= '1' and <= '9' => c - '0',
            _ => 0
        }).ToArray();

        var nonZero = parsed.Where(f => f > 0).DefaultIfEmpty(1).ToArray();
        _startFret = nonZero.Min();

        _stringInfos = Enumerable.Range(0, 6).Select(s =>
        {
            var fret = parsed[s];
            return new StringInfo(
                X: Margin + s * StrSpc,
                IsMuted: fret == -1,
                IsOpen: fret == 0,
                RelFret: fret > 0 ? fret - _startFret + 1 : 0);
        }).ToList();
    }
}
