{
  "servers": {
    "daeanne-dispatcher": {
      "type": "stdio",
      "command": "node",
      "args": ["${workspaceFolder}/mcp/dispatcher/index.js"],
      "env": {
        "DISPATCHER_URL": "http://127.0.0.1:47777"
      }
    },
    "daeanne-filesystem": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "${env:USERPROFILE}/.daeanne"]
    },
    "daeanne-memory": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-memory"]
    }
  }
}
